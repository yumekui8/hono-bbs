# このファイルをコピーして .dev.vars を作成してください
# cp .dev.vars.example .dev.vars

# ────────────────────────────────────────────────────────────
# Turnstile 設定 (必須)
# ────────────────────────────────────────────────────────────

# Cloudflare Turnstile サイトキー (公開値)
TURNSTILE_SITE_KEY=your-site-key

# Cloudflare Turnstile シークレットキー
# 本番環境は wrangler secret put TURNSTILE_SECRET_KEY で設定することを推奨
TURNSTILE_SECRET_KEY=your-secret-key

# ローカル開発時に Turnstile 検証をスキップする場合は true に設定
# DISABLE_TURNSTILE=true

# ────────────────────────────────────────────────────────────
# セッション設定
# ────────────────────────────────────────────────────────────

# Turnstile セッション有効期限 (分単位、0=無期限、デフォルト: 525600=1年)
# TURNSTILE_TOKEN_TTL=525600

# KV グローバルプレフィックス (hono-bbs 本体と KV を共有する場合に合わせること)
# KV_PREFIX=

# ────────────────────────────────────────────────────────────
# リダイレクト設定
# ────────────────────────────────────────────────────────────

# Turnstile 認証後のリダイレクト許可 UI ドメイン (カンマ区切り)
# 設定すると認証後にこのドメインへリダイレクトする (?returnTo= パラメータで指定)
# ALLOW_BBS_UI_DOMAINS=localhost:5173,app.example.com

# ────────────────────────────────────────────────────────────
# その他
# ────────────────────────────────────────────────────────────

# 許可する CORS オリジン (カンマ区切りで複数指定可、未設定時は *)
# CORS_ORIGIN=http://localhost:5173

# 許可するドメイン (カンマ区切りで複数指定可、未設定時は制限なし)
# BBS_ALLOW_DOMAIN=localhost:8788,example.com
